@page "/min-profil"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using TucBookingSystem.Client.Services
@inject UserStateService UserState

<div class="profile-page">
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                <span class="avatar-initial">@GetInitials()</span>
            </div>
            <h2>Välkommen, @GetFirstName()!</h2>
            <p class="user-email">@UserEmail</p>
        </div>

        <div class="profile-section">
            <h3>Min Information</h3>
            <div class="info-item">
                <label>Namn:</label>
                <span>@UserFullName</span>
            </div>
            <div class="info-item">
                <label>E-post:</label>
                <span>@UserEmail</span>
            </div>
            <div class="info-item">
                <label>Roll:</label>
                <span class="role-badge">@UserRole</span>
            </div>
        </div>

        <div class="profile-actions">
            <a href="/bookings" class="action-button">Mina bokningar</a>
            <a href="/rooms" class="action-button">Boka rum</a>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <a href="/admin" class="action-button">Admin sida</a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@code {
    private bool _hasLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoaded)
        {
            await UserState.LoadStateAsync();
            _hasLoaded = true;
            StateHasChanged();
        }
    }

    private string GetFirstName()
    {
        if (string.IsNullOrWhiteSpace(UserState.FullName))
        {
            return "Användare";
        }

        var parts = UserState.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts[0];
    }

    private string GetInitials()
    {
        if (string.IsNullOrWhiteSpace(UserState.FullName))
        {
            return "U";
        }

        var parts = UserState.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }

        return parts[0][0].ToString().ToUpperInvariant();
    }

    private string UserFullName => UserState.FullName ?? string.Empty;
    private string UserEmail => UserState.Email ?? string.Empty;
    private string UserRole => UserState.Role ?? string.Empty;
}
