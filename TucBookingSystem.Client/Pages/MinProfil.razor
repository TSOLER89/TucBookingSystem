@page "/min-profil"
@rendermode InteractiveServer
@using TucBookingSystem.Client.Services
@using TucBookingSystem.Shared.DTOs
@inject UserStateService UserState
@inject INotificationService NotificationService
@inject NavigationManager Nav

<div class="profile-page">
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                <span class="avatar-initial">@GetInitials()</span>
            </div>
            <h2>Välkommen, @GetFirstName()!</h2>
            <p class="user-email">@UserEmail</p>
        </div>

        <div class="profile-section">
            <h3>Min Information</h3>
            <div class="info-item">
                <label>Namn:</label>
                <span>@UserFullName</span>
            </div>
            <div class="info-item">
                <label>E-post:</label>
                <span>@UserEmail</span>
            </div>
            <div class="info-item">
                <label>Roll:</label>
                <span class="role-badge">@UserRole</span>
            </div>
        </div>

        <div class="profile-actions">
            <a href="/bookings" class="action-button">
                Mina Bokningar
            </a>
            <a href="/rooms" class="action-button">
                Boka Rum
            </a>
            @if (UserState.IsAdmin)
            {
                <a href="/admin" class="action-button">
                    Admin Sida
                </a>
            }
        </div>

        <div class="profile-section notifications-section">
            <div class="notifications-header">
                <h3>
                    🔔 Notifikationer
                    @if (_unreadCount > 0)
                    {
                        <span class="notification-badge-profile">@_unreadCount olästa</span>
                    }
                </h3>
                @if (_notifications.Any(n => !n.IsRead))
                {
                    <button class="mark-all-btn" @onclick="MarkAllAsRead">Markera alla som lästa</button>
                }
            </div>

            @if (_isLoadingNotifications)
            {
                <p class="loading-text">Laddar notifikationer...</p>
            }
            else if (!_notifications.Any())
            {
                <p class="no-notifications">Inga notifikationer ännu.</p>
            }
            else
            {
                <div class="notifications-list">
                    @foreach (var n in _notifications)
                    {
                        <div class="notification-item @(n.IsRead ? "read" : "unread")" @onclick="() => MarkAsRead(n)">
                            <div class="notification-dot @(n.IsRead ? "" : "unread-dot")"></div>
                            <div class="notification-content">
                                <p class="notification-message">@n.Message</p>
                                <span class="notification-time">@n.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool _hasLoaded = false;
    private List<NotificationDto> _notifications = new();
    private int _unreadCount = 0;
    private bool _isLoadingNotifications = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoaded)
        {
            await UserState.LoadStateAsync();
            _hasLoaded = true;

            if (!UserState.IsLoggedIn)
            {
                Nav.NavigateTo("/login");
            }
            else
            {
                await LoadNotifications();
                StateHasChanged();
            }
        }
    }

    private async Task LoadNotifications()
    {
        _isLoadingNotifications = true;
        _notifications = await NotificationService.GetMyNotificationsAsync();
        _unreadCount = _notifications.Count(n => !n.IsRead);
        _isLoadingNotifications = false;
    }

    private async Task MarkAsRead(NotificationDto notification)
    {
        if (notification.IsRead) return;
        await NotificationService.MarkAsReadAsync(notification.Id);
        notification.IsRead = true;
        _unreadCount = _notifications.Count(n => !n.IsRead);
    }

    private async Task MarkAllAsRead()
    {
        await NotificationService.MarkAllAsReadAsync();
        foreach (var n in _notifications)
            n.IsRead = true;
        _unreadCount = 0;
    }

    private string GetFirstName()
    {
        if (string.IsNullOrEmpty(UserState.FullName))
            return "Användare";

        var parts = UserState.FullName.Split(' ');
        return parts[0];
    }

    private string GetInitials()
    {
        if (string.IsNullOrEmpty(UserState.FullName))
            return "U";

        var parts = UserState.FullName.Split(' ');
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();

        return parts[0][0].ToString().ToUpper();
    }

    private string UserFullName => UserState.FullName;
    private string UserEmail => UserState.Email;
    private string UserRole => UserState.Role;
}
