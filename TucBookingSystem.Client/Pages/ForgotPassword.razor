@page "/forgot-password"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using TucBookingSystem.Shared.DTOs
@inject HttpClient Http
@using System.Text
@using System.Text.Json


<div class="login-page">
    <div class="login-container">
        <h3>Glömt lösenord</h3>
        <p>Skriv din e-post så skapar vi en återställningslänk.</p>

        <EditForm Model="forgotModel"
                  OnValidSubmit="HandleForgotPassword"
                  FormName="ForgotPasswordForm">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="forgotModel.Email"
                           class="input-field"
                           placeholder="Enter your email" />
            </div>

            <button type="submit" class="login-button">
                Skicka återställningslänk
            </button>

        </EditForm>

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="register-text">@message</p>
        }
    </div>
</div>

@code {
    private ForgotPasswordRequestDto forgotModel = new();
    private string message = "";

    private async Task HandleForgotPassword()
    {
        var response = await Http.PostAsJsonAsync("api/auth/forgot-password", forgotModel);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ForgotPasswordResponse>();
            message = result?.Message ?? "Om e-postadressen finns i systemet har ett e-postmeddelande skickats.";
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = "Ett fel uppstod. Försök igen senare.";
        }
    }

    public class ForgotPasswordResponse
    {
        public string Message { get; set; } = "";
    }
}