@page "/forgot-password"

<h3>Glömt lösenord</h3>
<p>Skriv din e-post så skickar vi en återställningslänk.</p>

<EditForm Model="forgotModel" OnValidSubmit="HandleForgotPassword">
    <DataAnnotationsValidator />

    <div class="form-group">
        <label>Email</label>
        <InputText @bind-Value="forgotModel.Email"
                   class="input-field"
                   placeholder="Enter your email" />
    </div>

    <button type="submit" class="login-button">
        Skicka återställningslänk
    </button>
</EditForm>

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}

@code {

    private ForgotPasswordModel forgotModel = new();
    private string message = "";

    private void HandleForgotPassword()
    {
        // Här kommer senare API-anrop
        message = "Om kontot finns har en återställningslänk skickats.";
    }

    public class ForgotPasswordModel
    {
        public string Email { get; set; } = "";
    }

}