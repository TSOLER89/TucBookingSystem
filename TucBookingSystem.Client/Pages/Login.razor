@page "/login"
@rendermode InteractiveServer
@using TucBookingSystem.Shared.DTOs
@using TucBookingSystem.Client.Services
@inject AuthService AuthService
@inject UserStateService UserState
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-container">

        <h3>Login</h3>

        <EditForm Model="loginModel" OnSubmit="HandleLogin">

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="loginModel.Email" class="input-field" placeholder="Enter your email" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText type="password" @bind-Value="loginModel.Password" class="input-field" placeholder="Enter your password" />
            </div>

            <p class="forgot-password">
                <a href="/forgot-password">Glömt lösenord?</a>
            </p>

            <button type="submit" class="login-button">Login</button>

            <p class="register-text">
                Har du inget konto?
                <a href="/register">Registrera</a>
            </p>
        </EditForm>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p class="error">@errorMessage</p>
        }

        @if (showSuccessMessage)
        {
            <p class="success">✅ Registrering lyckades! Du kan nu logga in.</p>
        }

    </div>
</div>

@code {
    private LoginRequestDto loginModel = new();
    private string errorMessage = "";
    private bool showSuccessMessage = false;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        showSuccessMessage = query["registered"] == "true";
    }

    private async Task HandleLogin()
    {
        errorMessage = "";

        try
        {
            var result = await AuthService.LoginAsync(loginModel);

            if (result != null)
            {
                await UserState.SetUserAsync(result.UserId, result.FullName, result.Email, result.Role);
                Nav.NavigateTo("/min-profil");
            }
            else
            {
                errorMessage = "Fel e-post eller lösenord.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ett fel uppstod: {ex.Message}";
        }
    }
}