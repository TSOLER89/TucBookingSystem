@page "/reset-password"
@using Microsoft.AspNetCore.WebUtilities
@using TucBookingSystem.Shared.DTOs
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject HttpClient Http

<div class="login-page">
    <div class="login-container">
        <h3>Återställ lösenord</h3>

        <EditForm Model="resetModel" OnValidSubmit="HandleResetPassword">
            <div class="form-group">
                <label>Nytt lösenord</label>
                <InputText type="password" class="input-field" @bind-Value="resetModel.NewPassword" />
            </div>

            <div class="form-group">
                <label>Bekräfta lösenord</label>
                <InputText type="password" class="input-field" @bind-Value="resetModel.ConfirmPassword" />
            </div>

            <button type="submit" class="login-button">Spara nytt lösenord</button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="error">@message</p>
        }
    </div>
</div>

@code {
    private string? token;
    private string? email;
    private string message = "";
    private ResetPasswordModel resetModel = new();

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var tokenValue))
            token = tokenValue;

        if (query.TryGetValue("email", out var emailValue))
            email = emailValue;
    }

    private async Task HandleResetPassword()
    {
        if (resetModel.NewPassword != resetModel.ConfirmPassword)
        {
            message = "Lösenorden matchar inte.";
            return;
        }

        var request = new ResetPasswordRequestDto
        {
            Email = email ?? "",
            Token = token ?? "",
            NewPassword = resetModel.NewPassword
        };

        var response = await Http.PostAsJsonAsync(
            "https://localhost:7214/api/auth/reset-password-api",
            request);

        if (response.IsSuccessStatusCode)
            message = "Lösenordet har uppdaterats!";
        else
            message = "Något gick fel.";
    }

    public class ResetPasswordModel
    {
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}