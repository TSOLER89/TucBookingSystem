@page "/register"
@rendermode InteractiveServer
@using TucBookingSystem.Shared.DTOs
@using TucBookingSystem.Client.Services
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="register-page">
<div class="register-container">

        <h3>Registrera</h3>

        <EditForm Model="registerModel" OnSubmit="HandleRegister" FormName="registerForm">

            <div class="form-group">
                <label>Förnamn</label>
                <InputText @bind-Value="firstName" class="input-field" placeholder="Ange ditt förnamn" />
            </div>

            <div class="form-group">
                <label>Efternamn</label>
                <InputText @bind-Value="lastName" class="input-field" placeholder="Ange ditt efternamn" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="registerModel.Email" class="input-field" placeholder="Ange din e-post" />
                <ValidationMessage For="@(() => registerModel.Email)" />
            </div>

            <div class="form-group">
                <label>Lösenord</label>
                <InputText type="password" @bind-Value="registerModel.Password" class="input-field" placeholder="Minst 6 tecken" />
                <ValidationMessage For="@(() => registerModel.Password)" />
            </div>

            <button type="submit" class="register-button">Registrera</button>

            <p class="login-text">
                Har du redan ett konto?
                <a href="/login">Logga in</a>
            </p>
        </EditForm>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="error">@errorMessage</p>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <p class="success">@successMessage</p>
    }

</div>
</div>

@code {
    private RegisterRequestDto registerModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private string firstName = "";
    private string lastName = "";

    private async Task HandleRegister(EditContext editContext)
    {
        errorMessage = "";
        successMessage = "";

        if (!editContext.Validate())
        {
            return;
        }

        registerModel.FullName = $"{firstName} {lastName}";

        try
        {
            var result = await AuthService.RegisterAsync(registerModel);

            if (result != null)
            {
                Nav.NavigateTo("/login?registered=true");
            }
            else
            {
                errorMessage = "Registreringen misslyckades. E-postadressen kan redan finnas.";
            }
        }
        catch
        {
            errorMessage = "Kunde inte ansluta till servern. Försök igen senare.";
        }
    }
}
