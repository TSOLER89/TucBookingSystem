@page "/register"
@using TucBookingSystem.Shared.DTOs
@using TucBookingSystem.Client.Services
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="register-page">
<div class="register-container">

    <h3>Registrera</h3>

    <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label>Namn</label>
            <InputText @bind-Value="registerModel.FullName" class="input-field" placeholder="Ange ditt namn" />
            <ValidationMessage For="@(() => registerModel.FullName)" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <InputText @bind-Value="registerModel.Email" class="input-field" placeholder="Ange din e-post" />
            <ValidationMessage For="@(() => registerModel.Email)" />
        </div>

        <div class="form-group">
            <label>Lösenord</label>
            <InputText type="password" @bind-Value="registerModel.Password" class="input-field" placeholder="Minst 6 tecken" />
            <ValidationMessage For="@(() => registerModel.Password)" />
        </div>

        <button type="submit" class="register-button">Registrera</button>

        <p class="login-text">
            Har du redan ett konto?
            <a href="/login">Logga in</a>
        </p>
    </EditForm>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="error">@errorMessage</p>
    }

</div>
</div>

@code {
    private RegisterRequestDto registerModel = new();
    private string errorMessage = "";

    private async Task HandleRegister()
    {
        errorMessage = "";

        var result = await AuthService.RegisterAsync(registerModel);

        if (result != null)
        {
            Nav.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Registreringen misslyckades. Försök igen.";
        }
    }
}
