@page "/"
@rendermode InteractiveServer
@using TucBookingSystem.Client.Services
@inject UserStateService UserState
@implements IDisposable

<PageTitle>TUC Bokningssystem</PageTitle>

<div class="hero">
    <div class="hero-content">
        <h1>TUC Bokningssystem</h1>
        <p>Boka grupprum och resurser enkelt och snabbt.</p>

        <div class="hero-buttons">
            <a href="/bookings" class="btn-primary">
                Boka rum
            </a>

            <a href="/rooms" class="btn-secondary">
                Visa rum
            </a>
        </div>

        @if (UserState.IsLoggedIn)
        {
            <div class="welcome-message">
                <p>Välkommen, @UserState.FullName!</p>
                <NavLink href="/min-profil" class="btn-profile">Min Profil</NavLink>
            </div>
        }
        else
        {
            <div class="login-prompt">
                <NavLink href="/login" class="btn-login">Logga in / Registrera</NavLink>
            </div>
        }
    </div>
</div>

@code {
    private bool _hasLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoaded)
        {
            await UserState.LoadStateAsync();
            _hasLoaded = true;
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        UserState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
    }
}