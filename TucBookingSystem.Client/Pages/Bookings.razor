@page "/bookings"
@using TucBookingSystem.Shared.DTOs
@using TucBookingSystem.Client.Components.Shared
@inject TucBookingSystem.Client.Services.BookingService BookingService
@inject TucBookingSystem.Client.Services.RoomService RoomService

<h3>Bokningar</h3>

@if (isLoading)
{
    <p>Laddar...</p>
}
else
{
    <div class="mb-4">
        <h4>Skapa ny bokning</h4>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <BookingForm BookingModel="newBooking"
                     Rooms="rooms"
                     StartTimeText="startTimeText"
                     EndTimeText="endTimeText"
                     StartTimeTextChanged="HandleStartTimeChanged"
                     EndTimeTextChanged="HandleEndTimeChanged"
                     OnSubmitBooking="HandleCreateBooking" />
    </div>

    <hr />

    <div>
        <h4>Mina bokningar</h4>
        <BookingList Bookings="bookings" />
    </div>
}

@code {
    private List<RoomDto> rooms = new();
    private List<BookingDto> bookings = new();

    private CreateBookingDto newBooking = new()
    {
        Date = DateOnly.FromDateTime(DateTime.Today)
    };

    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    // Tillfälligt tills riktig auth används i klienten
    private int userId = 1;

    private string startTimeText = "09:00";
    private string endTimeText = "10:00";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            rooms = await RoomService.GetRoomsAsync();
            bookings = await BookingService.GetMyBookingsAsync(userId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte ladda bokningssidan: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task HandleStartTimeChanged(string value)
    {
        startTimeText = value;
        return Task.CompletedTask;
    }

    private Task HandleEndTimeChanged(string value)
    {
        endTimeText = value;
        return Task.CompletedTask;
    }

    private async Task HandleCreateBooking()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (newBooking.RoomId == 0)
        {
            errorMessage = "Du måste välja ett rum.";
            return;
        }

        if (!TimeOnly.TryParse(startTimeText, out var startTime))
        {
            errorMessage = "Starttid är inte korrekt. Exempel: 09:00";
            return;
        }

        if (!TimeOnly.TryParse(endTimeText, out var endTime))
        {
            errorMessage = "Sluttid är inte korrekt. Exempel: 11:00";
            return;
        }

        newBooking.StartTime = startTime;
        newBooking.EndTime = endTime;

        var result = await BookingService.CreateBookingAsync(userId, newBooking);

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        successMessage = "Bokningen skapades.";

        newBooking = new CreateBookingDto
        {
            Date = DateOnly.FromDateTime(DateTime.Today)
        };

        startTimeText = "09:00";
        endTimeText = "10:00";

        bookings = await BookingService.GetMyBookingsAsync(userId);
    }
}