@page "/bookings"
@using TucBookingSystem.Shared.DTOs
@using TucBookingSystem.Client.Components.Shared
@inject TucBookingSystem.Client.Services.BookingService BookingService
@inject TucBookingSystem.Client.Services.RoomService RoomService

<h3 class="mb-4">Bokningar</h3>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Autentisering</h5>
        <p class="text-muted">
            Klistra in din JWT-token från login om du vill hämta, skapa eller avboka bokningar.
        </p>

        <div class="mb-3">
            <label class="form-label">JWT Token</label>
            <input class="form-control"
                   @bind="jwtToken"
                   placeholder="Klistra in token här" />
        </div>

        <button class="btn btn-secondary" @onclick="ApplyToken">
            Sätt token
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="alert alert-info">
        Laddar bokningssidan...
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="card-title mb-3">Skapa ny bokning</h4>

                    <BookingForm BookingModel="newBooking"
                                 Rooms="rooms"
                                 StartTimeText="startTimeText"
                                 EndTimeText="endTimeText"
                                 StartTimeTextChanged="HandleStartTimeChanged"
                                 EndTimeTextChanged="HandleEndTimeChanged"
                                 OnSubmitBooking="HandleCreateBooking" />
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="card-title mb-3">Mina bokningar</h4>

                    <BookingList Bookings="bookings"
                                 OnDeleteBooking="HandleDeleteBooking" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RoomDto> rooms = new();
    private List<BookingDto> bookings = new();

    private CreateBookingDto newBooking = new()
    {
        Date = DateOnly.FromDateTime(DateTime.Today)
    };

    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private string startTimeText = "09:00";
    private string endTimeText = "10:00";
    private string jwtToken = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRooms();
    }

    private async Task LoadRooms()
    {
        errorMessage = string.Empty;

        try
        {
            isLoading = true;
            rooms = await RoomService.GetRoomsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte ladda rum: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyToken()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(jwtToken))
        {
            errorMessage = "Du måste klistra in en token.";
            return;
        }

        try
        {
            BookingService.SetToken(jwtToken.Trim());
            bookings = await BookingService.GetMyBookingsAsync();
            successMessage = "Token satt. Dina bokningar hämtades.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte hämta bokningar: {ex.Message}";
        }
    }

    private Task HandleStartTimeChanged(string value)
    {
        startTimeText = value;
        return Task.CompletedTask;
    }

    private Task HandleEndTimeChanged(string value)
    {
        endTimeText = value;
        return Task.CompletedTask;
    }

    private async Task HandleCreateBooking()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(jwtToken))
        {
            errorMessage = "Du måste sätta en JWT-token först.";
            return;
        }

        if (newBooking.RoomId == 0)
        {
            errorMessage = "Du måste välja ett rum.";
            return;
        }

        if (!TimeOnly.TryParse(startTimeText, out var startTime))
        {
            errorMessage = "Starttid är inte korrekt. Exempel: 09:00";
            return;
        }

        if (!TimeOnly.TryParse(endTimeText, out var endTime))
        {
            errorMessage = "Sluttid är inte korrekt. Exempel: 11:00";
            return;
        }

        newBooking.StartTime = startTime;
        newBooking.EndTime = endTime;

        try
        {
            var result = await BookingService.CreateBookingAsync(newBooking);

            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Bokningen skapades.";

            ResetBookingForm();

            bookings = await BookingService.GetMyBookingsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte skapa bokning: {ex.Message}";
        }
    }

    private async Task HandleDeleteBooking(int bookingId)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(jwtToken))
        {
            errorMessage = "Du måste sätta en JWT-token först.";
            return;
        }

        try
        {
            var result = await BookingService.DeleteBookingAsync(bookingId);

            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Bokningen avbokades.";
            bookings = await BookingService.GetMyBookingsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte avboka bokningen: {ex.Message}";
        }
    }

    private void ResetBookingForm()
    {
        newBooking = new CreateBookingDto
        {
            Date = DateOnly.FromDateTime(DateTime.Today)
        };

        startTimeText = "09:00";
        endTimeText = "10:00";
    }
}