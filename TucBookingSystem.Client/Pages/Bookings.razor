@page "/bookings"
@using TucBookingSystem.Shared.DTOs
@inject TucBookingSystem.Client.Services.BookingService BookingService
@inject TucBookingSystem.Client.Services.RoomService RoomService

<h3>Bokningar</h3>

@if (isLoading)
{
    <p>Laddar...</p>
}
else
{
    <div class="mb-4">
        <h4>Skapa ny bokning</h4>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <EditForm Model="newBooking" OnValidSubmit="HandleCreateBooking">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Rum</label>
                <InputSelect class="form-control" @bind-Value="newBooking.RoomId">
                    <option value="0">Välj rum</option>
                    @foreach (var room in rooms)
                    {
                        <option value="@room.Id">@room.Name (@room.Location)</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Datum</label>
                <InputDate class="form-control" @bind-Value="newBooking.Date" />
            </div>

            <div class="mb-3">
                <label class="form-label">Starttid</label>
                <InputText class="form-control" @bind-Value="startTimeText" placeholder="09:00" />
            </div>

            <div class="mb-3">
                <label class="form-label">Sluttid</label>
                <InputText class="form-control" @bind-Value="endTimeText" placeholder="11:00" />
            </div>

            <div class="mb-3">
                <label class="form-label">Syfte</label>
                <InputText class="form-control" @bind-Value="newBooking.Purpose" />
            </div>

            <button class="btn btn-primary" type="submit">Skapa bokning</button>
        </EditForm>
    </div>

    <hr />

    <div>
        <h4>Mina bokningar</h4>

        @if (bookings.Count == 0)
        {
            <p>Du har inga bokningar ännu.</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Rum</th>
                        <th>Datum</th>
                        <th>Start</th>
                        <th>Slut</th>
                        <th>Syfte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in bookings)
                    {
                        <tr>
                            <td>@booking.RoomName</td>
                            <td>@booking.Date.ToString("yyyy-MM-dd")</td>
                            <td>@booking.StartTime</td>
                            <td>@booking.EndTime</td>
                            <td>@booking.Purpose</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private List<RoomDto> rooms = new();
    private List<BookingDto> bookings = new();

    private CreateBookingDto newBooking = new()
    {
        Date = DateOnly.FromDateTime(DateTime.Today)
    };

    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    // Tillfälligt hårdkodat tills ni kopplar riktig login/JWT
    private int userId = 1;

    private string startTimeText = "09:00";
    private string endTimeText = "10:00";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            rooms = await RoomService.GetRoomsAsync();
            bookings = await BookingService.GetMyBookingsAsync(userId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte ladda bokningssidan: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleCreateBooking()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (newBooking.RoomId == 0)
        {
            errorMessage = "Du måste välja ett rum.";
            return;
        }

        if (!TimeOnly.TryParse(startTimeText, out var startTime))
        {
            errorMessage = "Starttid är inte korrekt. Exempel: 09:00";
            return;
        }

        if (!TimeOnly.TryParse(endTimeText, out var endTime))
        {
            errorMessage = "Sluttid är inte korrekt. Exempel: 11:00";
            return;
        }

        newBooking.StartTime = startTime;
        newBooking.EndTime = endTime;

        var result = await BookingService.CreateBookingAsync(userId, newBooking);

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        successMessage = "Bokningen skapades.";
        newBooking = new CreateBookingDto
        {
            Date = DateOnly.FromDateTime(DateTime.Today)
        };

        startTimeText = "09:00";
        endTimeText = "10:00";

        bookings = await BookingService.GetMyBookingsAsync(userId);
    }
}