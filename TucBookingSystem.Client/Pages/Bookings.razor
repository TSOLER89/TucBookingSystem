@page "/bookings"
@using Microsoft.AspNetCore.Components
@using TucBookingSystem.Client.Components.Shared
@using TucBookingSystem.Shared.DTOs
@inject TucBookingSystem.Client.Services.BookingService BookingService
@inject TucBookingSystem.Client.Services.RoomService RoomService
@inject NavigationManager NavigationManager
@inject TucBookingSystem.Client.Services.UserStateService UserState

<PageTitle>Bokningar</PageTitle>

<div class="booking-page">
    <h3 class="booking-title">Bokningar</h3>

    <div class="booking-card mt-4">
        <h4 class="booking-subtitle">Mina bokningar</h4>

        <BookingList Bookings="@bookings"
                     OnEditBooking="@HandleEditBooking"
                     OnDeleteBooking="@HandleDeleteBooking" />

        @if (editingBookingId.HasValue)
        {
            <div class="mt-4">
                <h4 class="booking-subtitle">Ändra bokning</h4>

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">@successMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <BookingForm BookingModel="@editBooking"
                             Rooms="@rooms"
                             StartTimeText="@editStartTimeText"
                             EndTimeText="@editEndTimeText"
                             StartTimeTextChanged="@HandleEditStartTimeChanged"
                             EndTimeTextChanged="@HandleEditEndTimeChanged"
                             SubmitButtonText="Spara ändringar"
                             OnSubmitBooking="@HandleUpdateBooking" />

                <button type="button" class="btn btn-secondary mt-2" @onclick="CancelEditBooking">
                    Avbryt
                </button>
            </div>
        }
    </div>

    @if (isLoading)
    {
        <div class="booking-card">
            <p class="booking-loading">Laddar bokningar...</p>
        </div>
    }
    else
    {
        <div class="booking-card">
            <h4 class="booking-subtitle">Skapa ny bokning</h4>

            @if (!editingBookingId.HasValue)
            {
                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">@successMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }
            }

            <BookingForm BookingModel="@newBooking"
                         Rooms="@rooms"
                         StartTimeText="@startTimeText"
                         EndTimeText="@endTimeText"
                         StartTimeTextChanged="@HandleStartTimeChanged"
                         EndTimeTextChanged="@HandleEndTimeChanged"
                         SubmitButtonText="Skapa bokning"
                         OnSubmitBooking="@HandleCreateBooking" />
        </div>
    }
</div>

@code {
    private List<RoomDto> rooms = new();
    private List<BookingDto> bookings = new();

    [SupplyParameterFromQuery]
    public int? RoomId { get; set; }

    private CreateBookingDto newBooking = new()
    {
        Date = DateOnly.FromDateTime(DateTime.Today)
    };

    private CreateBookingDto editBooking = new()
    {
        Date = DateOnly.FromDateTime(DateTime.Today)
    };

    private bool isLoading = true;
    private int? editingBookingId;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private string startTimeText = "08:00";
    private string endTimeText = "09:00";
    private string editStartTimeText = "08:00";
    private string editEndTimeText = "09:00";

    protected override async Task OnInitializedAsync()
    {
        await UserState.LoadStateAsync();

        if (!UserState.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            rooms = await RoomService.GetRoomsAsync();
            bookings = await BookingService.GetMyBookingsAsync();

            if (RoomId.HasValue && rooms.Any(r => r.Id == RoomId.Value))
            {
                newBooking.RoomId = RoomId.Value;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte ladda bokningssidan: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task HandleStartTimeChanged(string value)
    {
        startTimeText = value;
        return Task.CompletedTask;
    }

    private Task HandleEndTimeChanged(string value)
    {
        endTimeText = value;
        return Task.CompletedTask;
    }

    private Task HandleEditStartTimeChanged(string value)
    {
        editStartTimeText = value;
        return Task.CompletedTask;
    }

    private Task HandleEditEndTimeChanged(string value)
    {
        editEndTimeText = value;
        return Task.CompletedTask;
    }

    private async Task HandleCreateBooking()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (newBooking.RoomId == 0)
        {
            errorMessage = "Du måste välja ett rum.";
            return;
        }

        if (!TimeOnly.TryParse(startTimeText, out var startTime))
        {
            errorMessage = "Starttid är inte korrekt. Exempel: 08:00";
            return;
        }

        if (!TimeOnly.TryParse(endTimeText, out var endTime))
        {
            errorMessage = "Sluttid är inte korrekt. Exempel: 09:00";
            return;
        }

        newBooking.StartTime = startTime;
        newBooking.EndTime = endTime;

        var result = await BookingService.CreateBookingAsync(newBooking);

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        successMessage = "Bokningen skapades.";

        newBooking = new CreateBookingDto
        {
            Date = DateOnly.FromDateTime(DateTime.Today)
        };

        startTimeText = "08:00";
        endTimeText = "09:00";

        bookings = await BookingService.GetMyBookingsAsync();
    }

    private Task HandleEditBooking(int bookingId)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        var booking = bookings.FirstOrDefault(b => b.Id == bookingId);
        if (booking is null)
        {
            errorMessage = "Kunde inte hitta bokningen som ska ändras.";
            return Task.CompletedTask;
        }

        editingBookingId = bookingId;
        editBooking = new CreateBookingDto
        {
            RoomId = booking.RoomId,
            Date = booking.Date,
            StartTime = booking.StartTime,
            EndTime = booking.EndTime,
            Purpose = booking.Purpose
        };
        editStartTimeText = booking.StartTime.ToString("HH:mm");
        editEndTimeText = booking.EndTime.ToString("HH:mm");

        return Task.CompletedTask;
    }

    private async Task HandleUpdateBooking()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (!editingBookingId.HasValue)
        {
            errorMessage = "Ingen bokning är vald för ändring.";
            return;
        }

        if (!TimeOnly.TryParse(editStartTimeText, out var startTime))
        {
            errorMessage = "Starttid är inte korrekt. Exempel: 08:00";
            return;
        }

        if (!TimeOnly.TryParse(editEndTimeText, out var endTime))
        {
            errorMessage = "Sluttid är inte korrekt. Exempel: 09:00";
            return;
        }

        var result = await BookingService.UpdateBookingAsync(editingBookingId.Value, new UpdateBookingDto
        {
            Date = editBooking.Date,
            StartTime = startTime,
            EndTime = endTime,
            Purpose = editBooking.Purpose
        });

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        successMessage = "Bokningen uppdaterades.";
        await CancelEditBooking();
        bookings = await BookingService.GetMyBookingsAsync();
    }

    private Task CancelEditBooking()
    {
        editingBookingId = null;
        editBooking = new CreateBookingDto
        {
            Date = DateOnly.FromDateTime(DateTime.Today)
        };
        editStartTimeText = "08:00";
        editEndTimeText = "09:00";
        return Task.CompletedTask;
    }

    private async Task HandleDeleteBooking(int bookingId)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        var booking = bookings.FirstOrDefault(b => b.Id == bookingId);
        var wasPassed = false;

        if (booking is not null)
        {
            var bookingEnd = booking.Date.ToDateTime(booking.EndTime);
            wasPassed = bookingEnd < DateTime.Now;
        }

        var result = await BookingService.DeleteBookingAsync(bookingId);

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        successMessage = wasPassed
            ? "Bokningen raderades."
            : "Bokningen avbokades.";

        if (editingBookingId == bookingId)
        {
            await CancelEditBooking();
        }

        bookings = await BookingService.GetMyBookingsAsync();
    }
}
