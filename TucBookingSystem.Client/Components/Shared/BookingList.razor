@using TucBookingSystem.Shared.DTOs

@if (Bookings == null || Bookings.Count == 0)
{
    <p class="booking-empty-text">Du har inga bokningar ännu.</p>
}
else
{
    <div class="booking-list-desktop">
        <div class="booking-table-wrapper">
            <table class="booking-table">
                <thead>
                    <tr>
                        <th>Rum</th>
                        @if (ShowUserColumn)
                        {
                            <th>Användare</th>
                        }
                        <th>Datum</th>
                        <th>Tid</th>
                        <th>Syfte</th>
                        <th>Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Bookings)
                    {
                        <tr>
                            <td>@booking.RoomName</td>
                            @if (ShowUserColumn)
                            {
                                <td>@booking.UserName</td>
                            }
                            <td>@booking.Date.ToString("yyyy-MM-dd")</td>
                            <td>@booking.StartTime.ToString("HH:mm") - @booking.EndTime.ToString("HH:mm")</td>
                            <td>@booking.Purpose</td>
                            <td>
                                <div class="booking-action-buttons">
                                    <button class="btn btn-secondary btn-sm"
                                            disabled="@IsBookingPassed(booking)"
                                            @onclick="() => EditClicked(booking.Id)">
                                        Ändra
                                    </button>

                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => DeleteClicked(booking.Id)">
                                        @(IsBookingPassed(booking) ? "Radera" : "Avboka")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    //Anpassning till liten skärm - visar varje bokning i en egen "kort" layout
    <div class="booking-list-mobile">
        @foreach (var booking in Bookings)
        {
            <div class="booking-mobile-card">
                <div class="booking-mobile-row">
                    <span class="booking-mobile-label">Rum</span>
                    <span>@booking.RoomName</span>
                </div>

                @if (ShowUserColumn)
                {
                    <div class="booking-mobile-row">
                        <span class="booking-mobile-label">Användare</span>
                        <span>@booking.UserName</span>
                    </div>
                }

                <div class="booking-mobile-row">
                    <span class="booking-mobile-label">Datum</span>
                    <span>@booking.Date.ToString("yyyy-MM-dd")</span>
                </div>

                <div class="booking-mobile-row">
                    <span class="booking-mobile-label">Tid</span>
                    <span>@booking.StartTime.ToString("HH:mm") - @booking.EndTime.ToString("HH:mm")</span>
                </div>

                <div class="booking-mobile-row">
                    <span class="booking-mobile-label">Syfte</span>
                    <span>@booking.Purpose</span>
                </div>

                <div class="booking-mobile-actions">
                    <button class="btn btn-secondary btn-sm"
                            disabled="@IsBookingPassed(booking)"
                            @onclick="() => EditClicked(booking.Id)">
                        Ändra
                    </button>

                    <button class="btn btn-danger btn-sm"
                            @onclick="() => DeleteClicked(booking.Id)">
                        @(IsBookingPassed(booking) ? "Radera" : "Avboka")
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public List<BookingDto> Bookings { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnEditBooking { get; set; }

    [Parameter]
    public EventCallback<int> OnDeleteBooking { get; set; }

    private async Task EditClicked(int bookingId)
    {
        await OnEditBooking.InvokeAsync(bookingId);
    }

    private async Task DeleteClicked(int bookingId)
    {
        await OnDeleteBooking.InvokeAsync(bookingId);
    }

    private bool ShowUserColumn => Bookings.Any(b => !string.IsNullOrWhiteSpace(b.UserName));

    private bool IsBookingPassed(BookingDto booking)
    {
        var bookingEnd = booking.Date.ToDateTime(booking.EndTime);
        return bookingEnd < DateTime.Now;
    }
}