@using TucBookingSystem.Shared.DTOs

<EditForm Model="BookingModel" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (ShowUserSelector)
    {
        <div class="mb-3">
            <label class="form-label">Boka åt</label>
            <InputSelect class="form-control" @bind-Value="BoundSelectedUserId">
                <option value="0">Välj användare</option>
                @foreach (var user in Users)
                {
                    <option value="@user.Id">@user.FullName (@user.Email)</option>
                }
            </InputSelect>
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Rum</label>
        <InputSelect class="form-control" @bind-Value="BookingModel.RoomId">
            <option value="0">Välj rum</option>
            @foreach (var room in Rooms)
            {
                <option value="@room.Id">@room.Name (@room.Location)</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label">Datum</label>
        <InputDate class="form-control" @bind-Value="BookingModel.Date" />
    </div>

    <div class="mb-3">
        <label class="form-label">Starttid</label>

        <select class="form-control" value="@StartTimeText" @onchange="HandleStartTimeChanged">
            @foreach (var time in TimeOptions)
            {
                <option value="@time">@time</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Sluttid</label>

        <select class="form-control" value="@EndTimeText" @onchange="HandleEndTimeChanged">
            @foreach (var time in TimeOptions)
            {
                <option value="@time">@time</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Syfte</label>
        <InputText class="form-control" @bind-Value="BookingModel.Purpose" />
    </div>

    <button class="btn btn-primary" type="submit">
        Skapa bokning
    </button>
</EditForm>

@code {
    [Parameter]
    public CreateBookingDto BookingModel { get; set; } = new();

    [Parameter]
    public List<RoomDto> Rooms { get; set; } = new();

    [Parameter]
    public string StartTimeText { get; set; } = "08:00";

    [Parameter]
    public string EndTimeText { get; set; } = "09:00";

    [Parameter]
    public EventCallback OnSubmitBooking { get; set; }

    [Parameter]
    public EventCallback<string> StartTimeTextChanged { get; set; }

    [Parameter]
    public EventCallback<string> EndTimeTextChanged { get; set; }

    [Parameter]
    public bool ShowUserSelector { get; set; }

    [Parameter]
    public List<UserDto> Users { get; set; } = new();

    [Parameter]
    public int SelectedUserId { get; set; }

    [Parameter]
    public EventCallback<int> SelectedUserIdChanged { get; set; }

    private async Task HandleSubmit()
    {
        await OnSubmitBooking.InvokeAsync();
    }

    private async Task HandleStartTimeChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "08:00";
        StartTimeText = value;
        await StartTimeTextChanged.InvokeAsync(value);
    }

    private async Task HandleEndTimeChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "09:00";
        EndTimeText = value;
        await EndTimeTextChanged.InvokeAsync(value);
    }

    private int BoundSelectedUserId
    {
        get => SelectedUserId;
        set
        {
            if (SelectedUserId == value)
            {
                return;
            }

            SelectedUserId = value;
            _ = SelectedUserIdChanged.InvokeAsync(value);
        }
    }

    private List<string> TimeOptions = new()
    {
        "08:00","08:30",
        "09:00","09:30",
        "10:00","10:30",
        "11:00","11:30",
        "12:00","12:30",
        "13:00","13:30",
        "14:00","14:30",
        "15:00","15:30",
        "16:00","16:30",
        "17:00","17:30",
        "18:00","18:30",
        "19:00","19:30",
        "20:00"
    };
}