@using TucBookingSystem.Client.Services
@inject UserStateService UserState
@inject NavigationManager Nav
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TUC Bokningssystem</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bookings">
                <span class="nav-icon">📅</span> Bokningar
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="rooms">
                <span class="nav-icon">🚪</span> Rum
            </NavLink>
        </div>

        @if (UserState.IsAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="nav-icon">⚙️</span> Admin
                </NavLink>
            </div>
        }

        @if (UserState.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="min-profil">
                    <span class="nav-icon">👤</span> Min profil
                </NavLink>
            </div>
        }

        <div class="nav-item px-3 logout-item">
            @if (UserState.IsLoggedIn)
            {
                <button class="nav-link logout-btn" @onclick="Logout">
                    <span class="nav-icon">🔓</span> Logga ut
                </button>
            }
            else
            {
                <button class="nav-link logout-btn" @onclick="Login">
                    <span class="nav-icon">🔐</span> Logga in
                </button>
            }
        </div>
    </nav>
</div>

@code {
    private bool _hasLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoaded)
        {
            await UserState.LoadStateAsync();
            _hasLoaded = true;
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        UserState.OnChange += StateHasChanged;
    }

    private async void Logout()
    {
        await UserState.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }

    private void Login()
    {
        Nav.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
    }
}
